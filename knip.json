{
  "$schema": "./node_modules/knip/schema.json",
  "ignoreDependencies": [
    "@tailwindcss/typography",
    "cloudflare",
    "entities",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignoreFiles": ["src/features/guestbook/**", "src/features/links/**"],
  "workspaces": {
    ".": {
      "entry": ["src/router.tsx"],
      "project": ["src/**/*.{ts,tsx}", "*.config.ts", "*.config.mjs"]
    }
  },
  "ignoreIssues": {
    "src/entry-server.ts": ["exports"],
    "src/features/content/server/content.ts": ["exports", "types"],
    "src/server/markdown.ts": ["unlisted"],
    "src/routeTree.gen.ts": ["exports"],
    "worker-configuration.d.ts": ["exports", "types", "unlisted"]
  }
}
