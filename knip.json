{
  "$schema": "./node_modules/knip/schema.json",
  "ignoreDependencies": ["cloudflare", "prettier"],
  "rules": {
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "files": "warn",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "enumMembers": "warn"
  },
  "entry": [
    "src/router.tsx",
    "src/routes/**/*.{ts,tsx}",
    "src/cli/*/index.ts",
    "scripts/gen-world-map.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "src/**/*.css",
    "scripts/**/*.ts",
    "*.config.ts",
    "*.config.mjs"
  ]
}
