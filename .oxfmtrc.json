{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": true,
  "tabWidth": 2,
  "singleQuote": true,
  "semi": false,
  "sortTailwindcss": {},
  "ignorePatterns": ["dist/**", "node_modules/**", "src/routeTree.gen.ts"],
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", "*.json5"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
