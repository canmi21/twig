{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "ffoni",
	"compatibility_date": "2026-04-20",
	"compatibility_flags": ["nodejs_compat"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	},
	"placement": {
		"mode": "smart"
	},
	"workers_dev": false,
	"preview_urls": false
}
