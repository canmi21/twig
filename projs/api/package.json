{
	"name": "api",
	"private": true,
	"license": "BSD-3-Clause",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --port 23316",
		"build": "wrangler deploy --dry-run --outdir=dist",
		"deploy": "bun run db:migrate:prod && wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply twig_sql --local",
		"db:migrate:prod": "wrangler d1 migrations apply twig_sql --remote",
		"db:reset": "rm -rf .wrangler/state/v3/d1 && bun run db:migrate",
		"types": "wrangler types",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.18",
		"jose": "^6.2.3"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"drizzle-kit": "^0.31.10",
		"wrangler": "^4.84.0"
	}
}
