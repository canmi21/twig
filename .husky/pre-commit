#!/bin/sh

# Collect staged files (Added, Copied, Modified, Renamed)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
  exit 0
fi

# Filter to source files oxfmt can handle
SRC_FILES=$(echo "$STAGED" | grep -E '\.(ts|tsx|js|jsx)$' || true)

# Formatting — run only on staged source files, blocks on failure
if [ -n "$SRC_FILES" ]; then
  echo "$SRC_FILES" | xargs oxfmt --write || exit 1
  echo "$SRC_FILES" | xargs chore 2>/dev/null || true
fi

# Re-stage only the files that were originally staged
echo "$STAGED" | xargs git add

# Lint — full project check (rules may span imports across files)
echo "Running oxlint..."
bun run lint:oxlint
OXLINT_EXIT=$?

echo "Running eslint..."
bun run lint:eslint
ESLINT_EXIT=$?

if [ $OXLINT_EXIT -ne 0 ] || [ $ESLINT_EXIT -ne 0 ]; then
  echo ""
  echo "Lint errors found. Commit blocked."
  exit 1
fi
