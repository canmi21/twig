{
  "name": "taki",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "bun run lint:oxlint && bun run lint:eslint",
    "lint:oxlint": "oxlint --tsconfig tsconfig.json .",
    "lint:oxlint:fix": "oxlint --tsconfig tsconfig.json --fix .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:fix": "bun run lint:oxlint:fix && bun run lint:eslint:fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "knip": "knip",
    "cf:typegen": "wrangler types worker-configuration.d.ts --env-interface CloudflareEnv",
    "db:generate": "drizzle-kit generate",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-router-ssr-query": "^1.166.7",
    "@tanstack/react-start": "^1.166.11",
    "@tanstack/router-plugin": "^1.166.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "entities": "^6.0.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "knip": "^5.86.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.10",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
