{
  "name": "taki",
  "version": "0.1.14",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "bun run lint:oxlint && bun run lint:eslint && knip",
    "lint:fix": "bun run lint:oxlint:fix && bun run lint:eslint:fix",
    "lint:oxlint": "oxlint --tsconfig tsconfig.json .",
    "lint:oxlint:fix": "oxlint --tsconfig tsconfig.json --fix .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "fmt": "oxfmt --write . && prettier --write --ignore-path /dev/null 'contents/**/*.md' 2>/dev/null || true && chore . && eslint . --fix > /dev/null 2>&1 || true",
    "fmt:check": "oxfmt --check .",
    "push": "bun run src/cli/push/index.ts",
    "pull": "bun run src/cli/pull/index.ts",
    "rebuild": "bun run src/cli/rebuild/index.ts",
    "watch": "bun run src/cli/watch/index.ts",
    "db:reset": "bun run src/cli/db-reset/index.ts",
    "db:seed": "bun run src/cli/db-seed/index.ts",
    "db:fresh": "bun run db:reset && bun run db:seed",
    "test": "vitest run --exclude '**/integration.test.ts'",
    "test:integration": "vitest run integration.test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "deploy": "wrangler d1 migrations apply taki-sql --remote && wrangler deploy"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@mingcute/react": "^1.4.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/rehype": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@tanstack/react-router": "^1.168.7",
    "@tanstack/react-start": "^1.167.12",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "feedsmith": "^2.9.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "prettier": "3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.9.4",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-oxlint": "^1.57.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^6.1.0",
    "miniflare": "^4.20260317.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "bun@1.3.10"
}
