{
	"name": "twig",
	"private": true,
	"license": "AGPL-3.0-or-later",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"prepare": "lefthook install || true",
		"dev": "bun --filter ffoni dev",
		"build": "bun --filter ffoni build",
		"test": "bun --filter ffoni test",
		"lint": "oxfmt --check . && prettier --check 'apps/*/**/*.svelte' && eslint .",
		"fmt": "oxfmt --write . && prettier --write 'apps/*/**/*.svelte'",
		"knip": "knip"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-better-tailwindcss": "^4.4.1",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"knip": "^6.6.0",
		"lefthook": "^2.1.6",
		"oxfmt": "^0.46.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"tailwindcss": "^4.2.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0"
	},
	"engines": {
		"node": ">=25"
	}
}
