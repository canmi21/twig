{
  "name": "taki",
  "version": "0.0.4",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "bun run lint:oxlint && bun run lint:eslint && knip",
    "lint:fix": "bun run lint:oxlint:fix && bun run lint:eslint:fix",
    "lint:oxlint": "oxlint --tsconfig tsconfig.json .",
    "lint:oxlint:fix": "oxlint --tsconfig tsconfig.json --fix .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "fmt": "oxfmt --write . && chore .",
    "fmt:check": "oxfmt --check .",
    "push": "bun run src/cli/push.ts",
    "pull": "bun run src/cli/pull.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.168.3",
    "@tanstack/react-start": "^1.167.5",
    "drizzle-orm": "^0.45.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.87.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "wrangler": "^4.74.0"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "bun@1.3.10"
