{
  "name": "taki",
  "version": "0.0.2",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "bun run lint:oxlint && bun run lint:eslint",
    "lint:oxlint": "oxlint --tsconfig tsconfig.json .",
    "lint:oxlint:fix": "oxlint --tsconfig tsconfig.json --fix .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:fix": "bun run lint:oxlint:fix && bun run lint:eslint:fix",
    "fmt": "oxfmt --write . && chore .",
    "fmt:check": "oxfmt --check .",
    "knip": "knip",
    "typecheck": "tsc --noEmit && tsc --noEmit -p drizzle/tsconfig.json",
    "cf:typegen": "wrangler types worker-configuration.d.ts --env-interface CloudflareEnv",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply taki-sql --local",
    "db:migrate:remote": "wrangler d1 migrations apply taki-sql --remote",
    "db:seed": "bun drizzle/seed.ts",
    "db:fresh": "rm -rf .wrangler/state && bun run db:migrate && bun run db:seed",
    "deploy": "bun run build && wrangler d1 migrations apply taki-sql --remote && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.29.0",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/rehype": "^4.0.2",
    "@shikijs/types": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "entities": "^7.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "knip": "^5.87.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "wrangler": "^4.74.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.10",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
